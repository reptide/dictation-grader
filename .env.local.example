# ─────────────────────────────────────────────
# Rename this file to .env.local and fill in
# your three free API keys, then run:
#   npm install
#   npm run dev
# ─────────────────────────────────────────────

# 1. Gemini (for grading)
#    Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL_PRIMARY=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.5-flash

# 2. Groq (for MP4/audio transcription)
#    Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# 3. Google Cloud Vision (optional — only needed for handwriting photo upload)
#    Get a free key at: https://console.cloud.google.com → enable Vision API
#    Leave as-is to skip this feature; everything else still works without it.
GOOGLE_VISION_API_KEY=optional_leave_blank_if_not_needed
